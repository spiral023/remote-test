# ============================
# Multi-Agent Devcontainer ENV
# ============================
# Diese Datei wird als Docker --env-file geladen.
# Ziel: Zuhause/Standard soll OHNE Proxy einfach funktionieren.
# Corporate-Optionen sind vorhanden, aber standardmäßig deaktiviert.
#
# Empfohlenes Vorgehen:
# - Zuhause / Standard: nichts ändern (Proxy-Variablen bleiben leer).
# - Corporate: entweder B1 (Px) ODER B2 (direkter Proxy) aktivieren.
# - Corporate TLS/SSL-Inspection: zusätzlich C aktivieren (Root CA).

# ------------------------------------------------
# A) Standard (Zuhause / ohne Proxy)  ✅ EMPFOHLEN
# ------------------------------------------------
# Empfehlung:
# - USE_LOCAL_PROXY=0
# - USE_CORP_CA=0
# - Alle Proxy-ENV leer lassen (sonst bekommst du ECONNREFUSED wie im Log).
USE_LOCAL_PROXY=0
USE_CORP_CA=0

# Proxy-ENV (leer = kein Proxy; das ist zuhause korrekt)
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=

http_proxy=
https_proxy=
all_proxy=

# Dinge, die NIE über Proxy sollen (auch im Corporate Setup sinnvoll):
# - host.docker.internal: wichtig für Host<->Container
# - localhost/127.0.0.1/::1: lokales Zeug
# - .local: lokale Domains
NO_PROXY=localhost,127.0.0.1,::1,host.docker.internal,.local
no_proxy=localhost,127.0.0.1,::1,host.docker.internal,.local


# ------------------------------------------------
# B1) Optional: Lokaler Proxy auf Windows via Px (Corporate)
# ------------------------------------------------
# Px ist hilfreich, wenn ihr Kerberos/NTLM/PAC habt und Tools im Container einfach
# "normalen HTTP Proxy" sprechen sollen.
#
# Empfehlung (Corporate MIT Px):
# - USE_LOCAL_PROXY=1
# - PX_PORT=3128 (Default ok)
# - PX_PAC_URL setzen, falls ihr PAC nutzt
# - Proxy-ENV auf http://host.docker.internal:${PX_PORT} setzen
#
# Empfehlung (Zuhause):
# - USE_LOCAL_PROXY=0 lassen
# - Proxy-ENV oben leer lassen

PX_PORT=3128

# Beispiel (Corporate):
# PX_PAC_URL=https://proxy.firma.local/proxy.pac
PX_PAC_URL=

# Zusätzliche Px Args (optional), z.B. Logging:
# PX_EXTRA_ARGS=--debug
PX_EXTRA_ARGS=

# Wenn du Px nutzt, setze die Proxy-ENV so (und USE_LOCAL_PROXY=1):
# HTTP_PROXY=http://host.docker.internal:3128
# HTTPS_PROXY=http://host.docker.internal:3128
# ALL_PROXY=http://host.docker.internal:3128
# http_proxy=http://host.docker.internal:3128
# https_proxy=http://host.docker.internal:3128
# all_proxy=http://host.docker.internal:3128


# ------------------------------------------------
# B2) Alternative: Direkter Corporate Proxy (ohne Px)
# ------------------------------------------------
# Empfehlung (Corporate OHNE Px):
# - USE_LOCAL_PROXY=0
# - Setze HTTP(S)_PROXY direkt auf euren Proxy
#
# Beispiel:
# HTTP_PROXY=http://proxy.firma.local:8080
# HTTPS_PROXY=http://proxy.firma.local:8080
# (Optional)
# ALL_PROXY=http://proxy.firma.local:8080
#
# Lowercase Varianten ggf. auch setzen (manche Tools nutzen bevorzugt diese):
# http_proxy=http://proxy.firma.local:8080
# https_proxy=http://proxy.firma.local:8080
# all_proxy=http://proxy.firma.local:8080


# ------------------------------------------------
# C) Optional: Corporate Root CA (TLS Inspection / interne CA)
# ------------------------------------------------
# Wenn eure Firma TLS/SSL inspeziert oder interne CAs nutzt, braucht der Container
# die Root-CA, sonst schlagen HTTPS Requests (Claude/Gemini/npm/curl/etc.) fehl.
#
# Vorgehen:
# - Lege PEM/CRT nach: .devcontainer/certs/  (NICHT committen)
# - Bootstrap/Script erzeugt daraus z.B. /home/node/.config/corp-ca.pem
#
# Empfehlung:
# - Zuhause: USE_CORP_CA=0 und NODE_EXTRA_CA_CERTS leer lassen
# - Corporate mit TLS-Inspection: USE_CORP_CA=1 und NODE_EXTRA_CA_CERTS setzen

# Pattern für Zertifikate (vom Bootstrap verwendet)
CORP_CA_GLOB=.devcontainer/certs/*.crt

# Wenn USE_CORP_CA=1:
# - Node-basierte Tools profitieren von NODE_EXTRA_CA_CERTS
# - NODE_USE_SYSTEM_CA optional, je nach Setup (häufig 1 sinnvoll)
NODE_USE_SYSTEM_CA=0

# Wichtig: Wenn hier ein Pfad gesetzt ist, MUSS die Datei existieren,
# sonst bekommst du Warnungen/Fehler. Daher standardmäßig leer lassen.
# Corporate-Beispiel:
# NODE_EXTRA_CA_CERTS=/home/node/.config/corp-ca.pem
NODE_EXTRA_CA_CERTS=

# (Optional, hilfreich für Python/curl/OpenSSL-Stacks)
# Corporate-Beispiel:
# SSL_CERT_FILE=/home/node/.config/corp-ca.pem
# REQUESTS_CA_BUNDLE=/home/node/.config/corp-ca.pem
SSL_CERT_FILE=
REQUESTS_CA_BUNDLE=

# (Wichtig: KEIN TLS-Disable wie NODE_TLS_REJECT_UNAUTHORIZED=0 – das ist unsicher.)