# ============================
# Multi-Agent Devcontainer ENV
# ============================
# Diese Datei ist eine Vorlage. Kopiere sie nach .devcontainer/devcontainer.env
# und aktiviere nur die Blöcke, die du wirklich brauchst.

# ------------------------------------------------
# A) Standard: Zuhause / ohne Proxy  ✅ EMPFOHLEN
# ------------------------------------------------
USE_LOCAL_PROXY=0
USE_CORP_CA=0
NO_PROXY=localhost,127.0.0.1,::1,host.docker.internal,.local
no_proxy=localhost,127.0.0.1,::1,host.docker.internal,.local

# ------------------------------------------------
# B) Optional: Lokaler Proxy via Px (Corporate)
# ------------------------------------------------
# Setze USE_LOCAL_PROXY=1 und starte auf Windows:
#   powershell -ExecutionPolicy Bypass -File .\.devcontainer\windows\start-px.ps1
# Standardziel im Container ist dann http://host.docker.internal:${PX_PORT}
PX_PORT=3128
PX_PAC_URL=
PX_EXTRA_ARGS=
# Optionales Override, falls dein lokaler Proxy anders erreichbar ist:
# LOCAL_PROXY_URL=http://host.docker.internal:3128

# ------------------------------------------------
# C) Alternative: Direkter Corporate Proxy ohne Px
# ------------------------------------------------
# HTTP_PROXY=http://proxy.firma.local:8080
# HTTPS_PROXY=http://proxy.firma.local:8080
# ALL_PROXY=http://proxy.firma.local:8080
# http_proxy=http://proxy.firma.local:8080
# https_proxy=http://proxy.firma.local:8080
# all_proxy=http://proxy.firma.local:8080

# ------------------------------------------------
# D) Optional: Corporate Root CA / TLS Inspection
# ------------------------------------------------
# Lege Zertifikate als .crt unter .devcontainer/certs/ ab (gitignored)
CORP_CA_GLOB=.devcontainer/certs/*.crt
# NODE_USE_SYSTEM_CA=1
# NODE_EXTRA_CA_CERTS=/home/node/.config/corp-ca.pem
# SSL_CERT_FILE=/home/node/.config/corp-ca.pem
# REQUESTS_CA_BUNDLE=/home/node/.config/corp-ca.pem
