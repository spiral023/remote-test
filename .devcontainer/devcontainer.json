{
  "name": "multi-agent-coding-container",
  "build": { "dockerfile": "Dockerfile" },
  "remoteUser": "node",

  "runArgs": [
    "--env-file",
    ".devcontainer/devcontainer.env",
    "--cap-drop=ALL",
    "--security-opt=no-new-privileges"
  ],

  "mounts": [
    "source=agent-codex,target=/home/node/.codex,type=volume",

    "source=agent-claude-dir,target=/home/node/.claude,type=volume",
    "source=agent-claude-json,target=/home/node/.persist/claude,type=volume",

    "source=agent-gemini,target=/home/node/.gemini,type=volume",
    "source=agent-xdg-gemini,target=/home/node/.config/gemini,type=volume"
  ],

  "containerEnv": {
    "HTTP_PROXY": "${localEnv:HTTP_PROXY}",
    "HTTPS_PROXY": "${localEnv:HTTPS_PROXY}",
    "ALL_PROXY": "${localEnv:ALL_PROXY}",
    "NO_PROXY": "${localEnv:NO_PROXY}",
    "NODE_EXTRA_CA_CERTS": "${localEnv:NODE_EXTRA_CA_CERTS}",
    "NODE_USE_SYSTEM_CA": "${localEnv:NODE_USE_SYSTEM_CA}"
  },

  "remoteEnv": {
    "HTTP_PROXY": "${containerEnv:HTTP_PROXY}",
    "HTTPS_PROXY": "${containerEnv:HTTPS_PROXY}",
    "ALL_PROXY": "${containerEnv:ALL_PROXY}",
    "NO_PROXY": "${containerEnv:NO_PROXY}",
    "NODE_EXTRA_CA_CERTS": "${containerEnv:NODE_EXTRA_CA_CERTS}",
    "NODE_USE_SYSTEM_CA": "${containerEnv:NODE_USE_SYSTEM_CA}"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "OpenAI.chatgpt",
        "anthropic.claude-code",
        "Google.gemini-cli-vscode-ide-companion"
      ]
    }
  },

  "postCreateCommand": "bash -lc '.devcontainer/scripts/bootstrap.sh'"
}